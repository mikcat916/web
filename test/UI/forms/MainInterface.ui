                 <string notr="true">

QPushButton#imgpush{
    border: 1px solid rgba(0,0,0,25);
    border-radius: 18px;

    /* 用背景图（比 border-image 更稳定，圆角一定生效） */
    border-image: url(assets/control2.png);
    background-repeat: no-repeat;
    background-position: center;
    background-color: rgba(255,255,255,10);
    /* Fluent 字体风格 */
    color: white;
    font-size: 18px;          /* 想更大就 20/22 */
    font-weight: 600;
    padding: 10px 14px;

    /* 文字居中 */
    text-align: center;
}

/* hover：更亮一点 + 边框更明显 */
QPushButton#imgpush:hover{
    border: 1px solid rgba(255,255,255,160);
}

/* pressed：轻微“下沉” */
QPushButton#imgpush:pressed{
    padding-top: 12px;     /* 比原来+2px */
    padding-left: 15px;
    border: 1px solid rgba(0,0,0,40);
}


