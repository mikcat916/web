   <string notr="true">

/* 2) TabWidget 作为“卡片容器” */
QTabWidget#tabWidget{
    background: transparent;   /* 外层透明，让我们用 pane 画卡片 */
}

/* 3) 关键：pane 才是 tabWidget 的主体区域（画圆角卡片） */
QTabWidget#tabWidget::pane{
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
        stop:0 #dff2ff,
        stop:1 #ffffff);
    border: 1px solid rgba(0,0,0,25);
    border-radius: 14px;
    top: -1px;                 /* 让 tab 不把圆角顶掉，可微调 */
}

/* 4) 关键：每个 tab page 默认是白底，必须设透明！否则就会“露白” */
QTabWidget#tabWidget QWidget{
    background: transparent;
}

/* 5) Tab 样式（可选，做得更像左图） */
QTabBar::tab{
    background: transparent;
    padding: 6px 14px;
    margin-left: 6px;
    color: rgba(0,0,0,180);
    border: 0px;
}

QTabBar::tab:selected{
    color: #0b4aa8;
    font-weight: 600;
}

QTabBar::tab:selected{
    border-bottom: 2px solid #0b4aa8;  /* 选中下划线 */
}

/* 6) 如果你的两个 page 里还有其它 widget 想要白底，就在 page 内部再单独设 */
</string>
