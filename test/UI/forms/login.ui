  <property name="styleSheet">
   <string notr="true">/* 整体背景：淡蓝到白 */
QWidget#Form{
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1,
                                stop:0 #bfe3ff, stop:0.45 #ffffff, stop:1 #ffffff);
}

/* 顶部蓝条 */
QFrame#topBar{
    background:#0b4aa8;
}

/* 圆形“设备照片” */
QFrame#photoFrame{
    background:#49a9ff;
    border:6px solid white;
    border-radius:60px; /* 120/2 */
}
QLabel#photoTextLabel{
    color:white;
    font-size:14px;
}
QLabel#iconLabel{
    color:white;
    font-size:28px;
}

/* 设备名称 */
QLabel#deviceNameLabel{
    color:#0b1a3a;
    font-size:26px;
    font-weight:700;
}

/* 密码圆点：默认空心 */


/* 深蓝按钮：默认给这些 id */
QPushButton#btn1, QPushButton#btn3, QPushButton#btn4, QPushButton#btn6, QPushButton#btn7, QPushButton#btn9{
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #0b4aa8, stop:1 #083a86);
    color:white;
    font-size:22px;
    font-weight:600;
    border:1px solid rgba(0,0,0,40);
    border-radius:26px;
}

/* 浅蓝按钮：2/5/8/0 */
QPushButton#btn2, QPushButton#btn5, QPushButton#btn8, QPushButton#btn0{
    background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #49a9ff, stop:1 #2f7fe0);
    color:white;
    font-size:22px;
    font-weight:600;
    border:1px solid rgba(0,0,0,40);
    border-radius:26px;
}

QPushButton:pressed{ padding-top:2px; }




</string>
